				msgbox(format("The {COLOR BLUE}True Random Mode{COLOR DARK_GREY} was {COLOR RED}disabled{COLOR DARK_GREY}!"), MSGBOX_DEFAULT)
				waitfanfare
				clearflag(FLAG_TRUE_RANDOM_MODE)
			}
		break
		case 1:
			msgbox(format("This will fully randomize every Pokemon in the wild or used by trainers, you can probably get all the first stages in just one route with this, this also disables the dexnav."), MSGBOX_DEFAULT)
		break
		case 2:
		case MULTI_B_PRESSED: 
			goto(Start_EventScript_Game_Modes_Other)
		break
	}
	
	goto(Start_EventScript_Game_Mode_True_Random_Mode)
	end
}

//Grindles Mode
script Start_EventScript_Game_Mode_Grindless_Mode{
	lockall

	if(!flag(FLAG_GRINDLESS_MODE)){
		msgbox(format("Do you want to {COLOR GREEN}enable{COLOR DARK_GREY} the {COLOR BLUE}Grindless Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_ENABLE, 0)
	}
	else{
		msgbox(format("Do you want to {COLOR RED}disable{COLOR DARK_GREY} the {COLOR BLUE}Grindless Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_DISABLE, 0)
	}

	switch(var(VAR_RESULT)){
		case 0:
			if(!flag(FLAG_GRINDLESS_MODE)){
				playfanfare(SE_SAVE)
				msgbox(format("The {COLOR BLUE}Grindless Mode{COLOR DARK_GREY} was {COLOR GREEN}enabled{COLOR DARK_GREY}!"), MSGBOX_DEFAULT)
				waitfanfare
				setflag(FLAG_GRINDLESS_MODE)
			}
			else{
				playfanfare(SE_BOO)
				msgbox(format("The {COLOR BLUE}Grindless Mode{COLOR DARK_GREY} was {COLOR RED}disabled{COLOR DARK_GREY}!"), MSGBOX_DEFAULT)
				waitfanfare
				clearflag(FLAG_GRINDLESS_MODE)
			}
		break
		case 1:
			msgbox(format("This will let you set the EVs from the summary screen, remove Levels and balance stats using the number of badges you have, this also affects enemy mons and enemy trainers so it is balanced for both"), MSGBOX_DEFAULT)
		break
		case 2:
		case MULTI_B_PRESSED: 
			goto(Start_EventScript_Game_Modes)
		break
	}
	
	goto(Start_EventScript_Game_Mode_Grindless_Mode)
	end
}

//Scalemon Mode
script Start_EventScript_Game_Mode_Scalemon_Mode{
	lockall

	if(!flag(FLAG_SCALEMON_MODE)){
		msgbox(format("Do you want to {COLOR GREEN}enable{COLOR DARK_GREY} the {COLOR BLUE}Scalemon Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_ENABLE, 0)
	}
	else{
		msgbox(format("Do you want to {COLOR RED}disable{COLOR DARK_GREY} the {COLOR BLUE}Scalemon Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_DISABLE, 0)
	}

	switch(var(VAR_RESULT)){
		case 0:
			if(!flag(FLAG_SCALEMON_MODE)){
				playfanfare(SE_SAVE)
				msgbox(format("The {COLOR BLUE}Scalemon Mode{COLOR DARK_GREY} was {COLOR GREEN}enabled{COLOR DARK_GREY}!"), MSGBOX_DEFAULT)
				waitfanfare
				setflag(FLAG_SCALEMON_MODE)
			}
			else{
				playfanfare(SE_BOO)
				msgbox(format("The {COLOR BLUE}Scalemon Mode{COLOR DARK_GREY} was {COLOR RED}disabled{COLOR DARK_GREY}!"), MSGBOX_DEFAULT)
				waitfanfare
				clearflag(FLAG_SCALEMON_MODE)
			}
		break
		case 1:
			msgbox(format("In Scalemon Mode, every Pokemon's stats, barring HP, are scaled to give them a BST as close to a certain BST depending on your badge count, with all recalculated stats being rounded down."), MSGBOX_DEFAULT)
		break
		case 2:
		case MULTI_B_PRESSED: 
			goto(Start_EventScript_Game_Modes)
		break
	}
	
	goto(Start_EventScript_Game_Mode_Scalemon_Mode)
	end
}

//Limit Gen Mode
script Start_EventScript_Game_Mode_Last_Gen_Mode{
	lockall
	if(!flag(FLAG_GEN_3_ONLY_MODE)){
		msgbox(format("Do you want to {COLOR GREEN}enable{COLOR DARK_GREY} the {COLOR BLUE}Limit Gen Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_ENABLE, 0)
	}
	else{
		msgbox(format("Do you want to {COLOR RED}disable{COLOR DARK_GREY} the {COLOR BLUE}Limit Gen Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_DISABLE, 0)
	}

	switch(var(VAR_RESULT)){
		case 0:
			if(!flag(FLAG_GEN_3_ONLY_MODE)){
				call(Start_EventScript_SetLastGen)
			}
			else{
				playfanfare(SE_BOO)
				msgbox(format("The {COLOR BLUE}Limit Gen Mode{COLOR DARK_GREY} was {COLOR RED}disabled{COLOR DARK_GREY}!"), MSGBOX_DEFAULT)
				waitfanfare
				clearflag(FLAG_GEN_3_ONLY_MODE)
				setvar(VAR_LAST_AVAILABLE_GEN, GEN_1)
			}
		break
		case 1:
			msgbox(format("In Limit Gen Mode, you limit the last generation you want Pokémon to appear but they will include some alternate forms depending on your generation."), MSGBOX_DEFAULT)
		break
		case 2:
		case MULTI_B_PRESSED: 
			goto(Start_EventScript_Game_Modes)
		break
	}
	
	goto(Start_EventScript_Game_Mode_Last_Gen_Mode)
	end
}

script Start_EventScript_SetLastGen{
	msgbox(format("Include Pokémon up to which generation?"), MSGBOX_DEFAULT)
	waitmessage
	setflag(FLAG_GEN_3_ONLY_MODE)
	scrollingmultichoice(SCROLLING_GENERATIONS, 0, 0, 5, FALSE)
	switch(var(VAR_RESULT)){
		case GEN_1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_1)
			msgbox(format("You will only see Pokémon from the {COLOR BLUE}First{COLOR DARK_GREY} generation!"))
		break
		case GEN_2:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_2)
			msgbox(format("You will only see Pokémon up to the {COLOR BLUE}Second{COLOR DARK_GREY} generation!"))
		break
		case GEN_3:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_3)
			msgbox(format("You will only see Pokémon up to the {COLOR BLUE}Third{COLOR DARK_GREY} generation!"))
		break
		case GEN_4:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_4)
			msgbox(format("You will only see Pokémon up to the {COLOR BLUE}Fourth{COLOR DARK_GREY} generation!"))
		break
		case GEN_5:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_5)
			msgbox(format("You will only see Pokémon up to the {COLOR BLUE}Fifth{COLOR DARK_GREY} generation!"))
		break
		case GEN_6:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_6)
			msgbox(format("You will only see Pokémon up to the {COLOR BLUE}Sixth{COLOR DARK_GREY} generation!"))
		break
		case GEN_7:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_7)
			msgbox(format("You will only see Pokémon up to the {COLOR BLUE}Seventh{COLOR DARK_GREY} generation!"))
		break
		case GEN_8:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, GEN_8)
			msgbox(format("You will only see Pokémon up to the {COLOR BLUE}Eight{COLOR DARK_GREY} generation!"))
		break
		case GEN_9:
		case MULTI_B_PRESSED:
		default:
			playfanfare(SE_BOO)
			waitfanfare
			setvar(VAR_LAST_AVAILABLE_GEN, 0)
			clearflag(FLAG_GEN_3_ONLY_MODE)
			msgbox(format("The {COLOR BLUE}Limit Gen Mode{COLOR DARK_GREY} was not enabled!"))
			return
		break
	}
	return
}

//Monotype Mode
script Start_EventScript_Game_Mode_Monotype_Mode{
	lockall
	if(!flag(FLAG_MONOTYPE_MODE)){
		msgbox(format("Do you want to {COLOR GREEN}enable{COLOR DARK_GREY} the {COLOR BLUE}Monotype Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_ENABLE, 0)
	}
	else{
		msgbox(format("Do you want to {COLOR RED}disable{COLOR DARK_GREY} the {COLOR BLUE}Monotype Mode{COLOR DARK_GREY}?"), MSGBOX_DEFAULT)
		waitmessage
		multichoice(0, 0, MULTI_GAME_MODE_DISABLE, 0)
	}

	switch(var(VAR_RESULT)){
		case 0:
			if(!flag(FLAG_MONOTYPE_MODE)){
				call(Start_EventScript_SetMonotypeType)
			}
			else{
				playfanfare(SE_BOO)
				msgbox(format("The {COLOR BLUE}Monotype Mode{COLOR DARK_GREY} was {COLOR RED}disabled{COLOR DARK_GREY}!"), MSGBOX_DEFAULT)
				waitfanfare
				clearflag(FLAG_MONOTYPE_MODE)
				setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_NONE)
			}
		break
		case 1:
			msgbox(format("In Monotype Mode, you limit the type of Pokémon you can use in your run to only 1 type."), MSGBOX_DEFAULT)
		break
		case 2:
		case MULTI_B_PRESSED: 
			goto(Start_EventScript_Game_Modes)
		break
	}
	
	goto(Start_EventScript_Game_Mode_Monotype_Mode)
	end
}

script Start_EventScript_SetMonotypeType{
	msgbox(format("Choose the type you want to use on this save file"), MSGBOX_DEFAULT)
	waitmessage
	setflag(FLAG_MONOTYPE_MODE)
	scrollingmultichoice(SCROLLING_TYPES, 0, 0, 5, FALSE)

	switch(var(VAR_RESULT)){
		case TYPE_NORMAL:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_NORMAL)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Normal{COLOR DARK_GREY} type!"))
