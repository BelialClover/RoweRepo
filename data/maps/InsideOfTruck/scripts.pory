			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_ROCK)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Rock{COLOR DARK_GREY} type!"))
		break
		case TYPE_BUG:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_BUG)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Bug{COLOR DARK_GREY} type!"))
		break
