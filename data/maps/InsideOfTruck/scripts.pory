mapscripts InsideOfTruck_MapScripts {}

script Start_EventScript_Starter_No_Exploit {
	release
	end
}

script Start_EventScript_Game_Level {
	lockall
	msgbox(format("Please select the difficulty level you\nwant to play in."), MSGBOX_DEFAULT)
	waitmessage
	multichoice(0, 0, MULTI_GAME_LEVEL, 0)
	switch (var(VAR_RESULT)) {
		case 0: goto(Start_EventScript_Game_Level_Easy) break
		case 1: goto(Start_EventScript_Game_Level_Normal) break
		case 2: goto(Start_EventScript_Game_Level_Hard) break
		case MULTI_B_PRESSED: goto(Start_EventScript_Game_Level) break
	}
	end
}
script Start_EventScript_Game_Level_Easy {
	lockall
	msgbox(format("Do you want to play on {COLOR GREEN}Easy mode{COLOR DARK_GREY}?\nThis can't be changed later!"), MSGBOX_YESNO)
	if (var(VAR_RESULT) == NO) {
		goto(Start_EventScript_Game_Level)
	}
	setflag(FLAG_DIFFICULTY_SET)
	setvar(VAR_DIFFICULTY, DIFFICULTY_EASY)
	setvar(VAR_LEVEL_CAP_LEVEL, 2)
	goto(Start_EventScript_Difficulty_Save)
	end
}

script Start_EventScript_Game_Level_Normal {
	lockall
	msgbox(format("Do you want to play on {COLOR BLUE}Normal mode{COLOR DARK_GREY}?\nThis can be changed later!"), MSGBOX_YESNO)
	if (var(VAR_RESULT) == NO) {
		goto(Start_EventScript_Game_Level)
	}
	setflag(FLAG_DIFFICULTY_SET)
	setvar(VAR_DIFFICULTY, DIFFICULTY_NORMAL)
	setvar(VAR_LEVEL_CAP_LEVEL, 1)
	goto(Start_EventScript_Difficulty_Save)
	end
}

script Start_EventScript_Game_Level_Hard {
	lockall
	msgbox(format("Do you want to play on {COLOR RED}Hard mode{COLOR DARK_GREY}?\nThis can be changed later!"), MSGBOX_YESNO)
	if (var(VAR_RESULT) == NO) {
		goto(Start_EventScript_Game_Level)
	}
	setflag(FLAG_DIFFICULTY_SET)
	setvar(VAR_DIFFICULTY, DIFFICULTY_HARD)
	setvar(VAR_LEVEL_CAP_LEVEL, 0)
	goto(Start_EventScript_Difficulty_Save)
	end
}

script Start_EvenScript_Flagset_Difficulty {
	if (flag(FLAG_DIFFICULTY_SET)) {
		goto(Start_EventScript_Give_Items)
	}
	setvar(VAR_DIFFICULTY, DIFFICULTY_NORMAL)
	setvar(VAR_LEVEL_CAP_LEVEL, 1)
	goto(Start_EventScript_Give_Items)
	end
}

script Start_EventScript_SetUpclock {
	lock
	faceplayer
	msgbox(format("Please set up the clock before starting."), MSGBOX_SIGN)
	end
}

//Intro Flags per Gender
script Start_EventScript_SetIntroFlags {
	lockall
	checkplayergender
	if (var(VAR_RESULT) == MALE) {
		goto(Start_EventScript_SetIntroFlagsMale)
	}
	if (var(VAR_RESULT) == FEMALE) {
		goto(Start_EventScript_SetIntroFlagsFemale)
	}
	return
}

script Start_EventScript_SetIntroFlagsMale {
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_MOM)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_TRUCK)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_RIVAL_MOM)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_RIVAL_SIBLING)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_2F_POKE_BALL)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_TRUCK)
	setvar(VAR_LITTLEROOT_INTRO_STATE, 1)
	setvar(VAR_LITTLEROOT_HOUSES_STATE_BRENDAN, 3)
	call(Start_EvenScript_StoryFlagset)
	return
}

script Start_EventScript_SetIntroFlagsFemale {
	setvar(VAR_LITTLEROOT_INTRO_STATE, 2)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_MOM)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_TRUCK)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_RIVAL_MOM)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_RIVAL_SIBLING)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_2F_POKE_BALL)
	setvar(VAR_LITTLEROOT_HOUSES_STATE_MAY, 3)
	setflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_TRUCK)
	call(Start_EvenScript_StoryFlagset)
	return
}

