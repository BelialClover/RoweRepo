			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_GHOST)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Ghost{COLOR DARK_GREY} type!"))
		break
		case TYPE_STEEL:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_STEEL)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Steel{COLOR DARK_GREY} type!"))
		break
		case TYPE_FIRE - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_FIRE)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Fire{COLOR DARK_GREY} type!"))
		break
		case TYPE_WATER - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_WATER)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Water{COLOR DARK_GREY} type!"))
		break
		case TYPE_GRASS - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_GRASS)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Grass{COLOR DARK_GREY} type!"))
		break
		case TYPE_ELECTRIC - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_ELECTRIC)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Electric{COLOR DARK_GREY} type!"))
		break
		case TYPE_PSYCHIC - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_PSYCHIC)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Psychic{COLOR DARK_GREY} type!"))
		break
		case TYPE_ICE - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_ICE)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Ice{COLOR DARK_GREY} type!"))
		break
		case TYPE_DRAGON - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_DRAGON)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Dragon{COLOR DARK_GREY} type!"))
		break
		case TYPE_DARK - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_DARK)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Dark{COLOR DARK_GREY} type!"))
		break
		case TYPE_FAIRY - 1:
			playfanfare(SE_SAVE)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, TYPE_FAIRY)
			msgbox(format("You will only be able to use Pokémon from the {COLOR BLUE}Fairy{COLOR DARK_GREY} type!"))
		break
		case NUMBER_OF_MON_TYPES - 1:
			call(Start_EventScript_SetMonotypeType_Random)
		case MULTI_B_PRESSED:
		default:
			playfanfare(SE_BOO)
			waitfanfare
			setvar(VAR_MONOTYPE_MODE_TYPE, 0)
			clearflag(FLAG_MONOTYPE_MODE)
			msgbox(format("The {COLOR BLUE}Monotype Mode{COLOR DARK_GREY} was not enabled!"))
			return
		break
	}
	return
}

