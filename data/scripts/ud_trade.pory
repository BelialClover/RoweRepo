script UDTrade_EventScript_OpenDimensionList {
	lockall
	faceplayer
	message(UDTrade_Text_WhichDimension)
	waitmessage
	delay(28)
	special(OpenUDTradeMenu)
	waitstate
}

script UDTrade_EventScript_SpeciesNotAllowed {
	msgbox(UDTrade_Text_SpeciesNotAllowed)
	goto(UDTrade_EventScript_OpenDimensionList)
}

script UDTrade_EventScript_ItemNotAllowed {
	msgbox(UDTrade_Text_ItemNotAllowed)
	goto(UDTrade_EventScript_OpenDimensionList)
}

script UDTrade_EventScript_MoveNotAllowed {
	msgbox(UDTrade_Text_MoveNotAllowed)
	goto(UDTrade_EventScript_OpenDimensionList)
}

script UDTrade_EventScript_on_Mantainance {
	msgbox(UDTrade_Text_on_Mantainance)
	goto(UDTrade_EventScript_OpenDimensionList)
}

script UDTrade_EventScript_Mode_Not_Allowed_To_Trade {
	msgbox(UDTrade_Text_Mode_Not_Allowed_To_Trade)
	goto(UDTrade_EventScript_OpenDimensionList)
}

text UDTrade_Text_WhichDimension {
	"With which Ultra Dimension do you\n"
	"wish to link with?"
}

text UDTrade_Text_on_Mantainance {
	"I'm sorry, but {STR_VAR_1} is not\n"
	"working at the moment."
}

text UDTrade_Text_SpeciesNotAllowed {
	"I'm sorry, but {STR_VAR_1} is not\n"
	"allowed in the {STR_VAR_2}."
}

text UDTrade_Text_ItemNotAllowed {
	"I'm sorry, but {STR_VAR_1} can't carry\n"
	"a Held Item into the {STR_VAR_2}."
}

text UDTrade_Text_Mode_Not_Allowed_To_Trade {
	"I'm sorry, but you can't trade\n"
	"with the modes you have enabled."
}

text UDTrade_Text_MoveNotAllowed {
	"I'm sorry, but {STR_VAR_1} can't go\n"
	"into the {STR_VAR_2} while\l"
	"knowing the move {STR_VAR_3}."
}
