	setwildbattle(SPECIES_LUCARIO, LEVEL_SCALE_WILD_BOSS, ITEM_LUCARIONITE_Z)
	setflag(FLAG_SYS_CTRL_OBJ_DELETE)
	dowildbattle
	clearflag(FLAG_SYS_CTRL_OBJ_DELETE)
	specialvar(VAR_RESULT, GetBattleOutcome)
    switch(var(VAR_RESULT)){
        case B_OUTCOME_CAUGHT:
        case B_OUTCOME_WON:
            setflag(FLAG_GOT_LUCARIO_MEGA_STONE_Z)
            setflag(FLAG_DISABLE_PORTALS)
            fadescreenswapbuffers(FADE_TO_BLACK)
            removeobject(VAR_LAST_TALKED)
            fadescreenswapbuffers(FADE_FROM_BLACK)
			if(var(VAR_RESULT) == B_OUTCOME_WON){
				msgbox(format("Lucario escaped but something was left behind!"), MSGBOX_DEFAULT)
				giveitem(ITEM_LUCARIONITE_Z, 1)
			}
        break
        case B_OUTCOME_RAN:
        case B_OUTCOME_PLAYER_TELEPORTED:
            fadescreenswapbuffers(FADE_TO_BLACK)
            removeobject(VAR_LAST_TALKED)
            fadescreenswapbuffers(FADE_FROM_BLACK)
            msgbox(format("Lucario escaped!"), MSGBOX_DEFAULT)
        break
    }
	release
	end
}

script Common_Eventscript_Enable_Alphas_Garchomp_Z{
	call(Common_Eventscript_Enable_Alphas)
	if(flag(FLAG_GOT_GARCHOMP_MEGA_STONE_Z)){
		setflag(FLAG_DISABLE_PORTALS)
	}
}

script Common_EventScript_Alpha_Garchomp_Z{
	lock
	faceplayer
	call(Common_EventScript_SetAlphaDefaultData)
	playmoncry(SPECIES_GARCHOMP, 2)
	setwildbattle(SPECIES_GARCHOMP, LEVEL_SCALE_WILD_BOSS, ITEM_GARCHOMPITE_Z)
	setflag(FLAG_SYS_CTRL_OBJ_DELETE)
	dowildbattle
	clearflag(FLAG_SYS_CTRL_OBJ_DELETE)
	specialvar(VAR_RESULT, GetBattleOutcome)
    switch(var(VAR_RESULT)){
        case B_OUTCOME_CAUGHT:
        case B_OUTCOME_WON:
            setflag(FLAG_GOT_GARCHOMP_MEGA_STONE_Z)
            setflag(FLAG_DISABLE_PORTALS)
            fadescreenswapbuffers(FADE_TO_BLACK)
            removeobject(VAR_LAST_TALKED)
            fadescreenswapbuffers(FADE_FROM_BLACK)
			if(var(VAR_RESULT) == B_OUTCOME_WON){
				msgbox(format("Garchomp escaped but something was left behind!"), MSGBOX_DEFAULT)
				giveitem(ITEM_GARCHOMPITE_Z, 1)
			}
        break
        case B_OUTCOME_RAN:
        case B_OUTCOME_PLAYER_TELEPORTED:
            fadescreenswapbuffers(FADE_TO_BLACK)
            removeobject(VAR_LAST_TALKED)
            fadescreenswapbuffers(FADE_FROM_BLACK)
            msgbox(format("Garchomp escaped!"), MSGBOX_DEFAULT)
        break
    }
	release
	end
}
