script Common_EventScript_PkmnCenterJack_ChangeSeason{
	msgbox(format("Please chose the season you like the best."), MSGBOX_DEFAULT)
	waitmessage
	scrollingmultichoice(SCROLLING_SEASONS, 0, 0, 5, TRUE)
	switch(var(VAR_RESULT)){
		case SEASON_SPRING:
			setvar(VAR_CURRENT_SEASON, SEASON_SPRING)
			setflag(FLAG_SYS_DISABLE_AUTOMATIC_SEASON)
			msgbox(format("You will play in Spring!"))
		break
		case SEASON_SUMMER:
			setvar(VAR_CURRENT_SEASON, SEASON_SUMMER)
			setflag(FLAG_SYS_DISABLE_AUTOMATIC_SEASON)
			msgbox(format("You will play in Summer!"))
		break
		case SEASON_AUTUMN:
			setvar(VAR_CURRENT_SEASON, SEASON_AUTUMN)
			setflag(FLAG_SYS_DISABLE_AUTOMATIC_SEASON)
			msgbox(format("You will play in Autumn!"))
		break
		case SEASON_WINTER:
			setvar(VAR_CURRENT_SEASON, SEASON_WINTER)
			setflag(FLAG_SYS_DISABLE_AUTOMATIC_SEASON)
			msgbox(format("You will play in Winter!"))
		break
		default:
			msgbox(format("The season will update according to the real time!"))
		break
		case MULTI_B_PRESSED:
		break
	}
	goto(Common_EventScript_PkmnCenterJack)
}

script Common_EventScript_PkmnCenterJack_ChangeYear{
	msgbox(format("Please tell me the current year"), MSGBOX_DEFAULT)
	waitmessage
	scrollingmultichoice(SCROLLING_YEAR, 0, 0, 5, TRUE)
	switch(var(VAR_RESULT)){
		default:
			copyvar(VAR_TEMP_1, VAR_RESULT)
			goto(Common_EventScript_PkmnCenterJack_ChangeMonth)
		break
		case MULTI_B_PRESSED:
			setvar(VAR_TEMP_1, 0)
			setvar(VAR_TEMP_1, 1)
			setvar(VAR_TEMP_1, 2)
		break
	}
	goto(Common_EventScript_PkmnCenterJack)
}

script Common_EventScript_PkmnCenterJack_ChangeMonth{
	msgbox(format("Please tell me the current month"), MSGBOX_DEFAULT)
	waitmessage
	scrollingmultichoice(SCROLLING_MONTH, 0, 0, 5, TRUE)
	switch(var(VAR_RESULT)){
		default:
			copyvar(VAR_TEMP_2, VAR_RESULT)
			goto(Common_EventScript_PkmnCenterJack_ChangeDay)
		break
		case MULTI_B_PRESSED:
			setvar(VAR_TEMP_1, 0)
			setvar(VAR_TEMP_1, 1)
			setvar(VAR_TEMP_1, 2)
		break
	}
	goto(Common_EventScript_PkmnCenterJack)
}

script Common_EventScript_PkmnCenterJack_ChangeDay{
	msgbox(format("Please tell me the current day"), MSGBOX_DEFAULT)
	waitmessage
	scrollingmultichoice(SCROLLING_DAY, 0, 0, 5, TRUE)
	switch(var(VAR_RESULT)){
		default:
			copyvar(VAR_TEMP_3, VAR_RESULT)
			setflag(FLAG_SYS_RESET_DATE)
			setvar(VAR_OVERWORLD_SPECIALS, SPECIAL_SET_DATE)
			drawbox
			msgbox(format("You Changed the Date!"))
		break
		case MULTI_B_PRESSED:
			setvar(VAR_TEMP_1, 0)
			setvar(VAR_TEMP_1, 1)
			setvar(VAR_TEMP_1, 2)
			//setvar(VAR_RTC_FAKE_DAYS, 0)
		break
	}
	goto(Common_EventScript_PkmnCenterJack)
}

