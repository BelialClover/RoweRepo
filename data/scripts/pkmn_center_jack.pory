script Common_Mega_Stone_Guru_No_Braclet{
	msgbox(format("I'm an stone collector, I have a big collection but I don't know what to do with it right now, maybe I could sell them in a time of need."), MSGBOX_NPC)
	release
	end
}

script Common_Mega_Stone_Guru_XY{
	lock
	faceplayer
	if(!flag(FLAG_UNLOCK_MEGA_STONES)){
		goto(Common_Mega_Stone_Guru_No_Braclet)
	}
	setvar(VAR_SHOP_TYPE, MART_TYPE_NORMAL) //Pokemon Shop
	setvar(VAR_SHOP_MONEY_TYPE, MART_MONEY_TYPE_BATTLE_POINTS) //Battle Points
	message(format("Hello, I sell rare stones from Kalos!, How may I serve you?"))
	waitmessage
	pokemart(Mart_Guru_Stones_XY)
	msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
	release
	end
}

