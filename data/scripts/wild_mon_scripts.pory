script EventScript_Sudowoodo {
	lock
	faceplayer
	waitse
	playse(SE_SUDOWOODO_SHAKE)
	applymovement(VAR_LAST_TALKED, Sudowoodo_Movement_SudowoodoShake)
	waitmovement(0)
	release
	end
}

script EventScript_WaterSudowoodo {
	lock
	faceplayer
	if (!flag(FLAG_BADGE03_GET)) {
		goto(EventScript_WaterBonsly)
	}
	if (flag(FLAG_TEMP_5)) {
		goto(EventScript_WaterBonsly)
	}
	special(DoWateringBerryTreeAnim)
	waitstate
	waitse
	playse(SE_SUDOWOODO_SHAKE)
	applymovement(VAR_LAST_TALKED, Sudowoodo_Movement_SudowoodoShake)
	waitmovement(0)
	msgbox(gText_Sudowoodo_Attacked, MSGBOX_DEFAULT)
	closemessage
	waitse
	playmoncry(SPECIES_SUDOWOODO, 2)
	delay(40)
	waitmoncry
	setwildbattle(SPECIES_SUDOWOODO, 1, ITEM_NONE)
	setflag(FLAG_SYS_CTRL_OBJ_DELETE)
	dowildbattle
	clearflag(FLAG_SYS_CTRL_OBJ_DELETE)
	specialvar(VAR_RESULT, GetBattleOutcome)
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		goto(EventScript_DefeatedSudowoodo)
	}
	if (var(VAR_RESULT) == B_OUTCOME_RAN) {
		goto(EventScript_DefeatedSudowoodo)
	}
	if (var(VAR_RESULT) == B_OUTCOME_PLAYER_TELEPORTED) {
		goto(EventScript_DefeatedSudowoodo)
	}
	release
	end
}

