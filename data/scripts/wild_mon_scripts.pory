script EventScript_Kecleon {
	goto(EventScript_AskUseDevonScope)
	//msgbox(Kecleon_Text_SomethingUnseeable, MSGBOX_DEFAULT)
	release
	end
}

script EventScript_AskUseDevonScope {
	msgbox(Kecleon_Text_WantToUseDevonScope, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		goto(EventScript_BattleKecleon)
	}
	release
	end
}

script EventScript_BattleKecleon {
	msgbox(Kecleon_Text_UseDevonScopeMonAttacked, MSGBOX_DEFAULT)
	closemessage
	applymovement(VAR_LAST_TALKED, Common_Movement_FacePlayer)
	waitmovement(0)
	applymovement(VAR_LAST_TALKED, Movement_KecleonAppears)
	waitmovement(0)
	waitse
	playmoncry(SPECIES_KECLEON, 2)
	delay(40)
	waitmoncry
	setwildbattle(SPECIES_KECLEON, 1, ITEM_NONE)
	setflag(FLAG_SYS_CTRL_OBJ_DELETE)
	dowildbattle
	clearflag(FLAG_SYS_CTRL_OBJ_DELETE)
	specialvar(VAR_RESULT, GetBattleOutcome)
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		goto(EventScript_RemoveKecleon)
	}
	if (var(VAR_RESULT) == B_OUTCOME_RAN) {
		goto(EventScript_RemoveKecleon)
	}
	if (var(VAR_RESULT) == B_OUTCOME_PLAYER_TELEPORTED) {
		goto(EventScript_RemoveKecleon)
	}
	release
	end
}

script EventScript_RemoveKecleon {
	goto(Common_EventScript_RemoveStaticPokemon)
	end
}

movement Movement_KecleonAppears {
	set_visible
	delay_4
	set_invisible
	delay_4
	set_visible
	delay_4
	set_invisible
	delay_4
	set_visible
	delay_8
	set_invisible
	delay_8
	set_visible
	delay_8
	set_invisible
	delay_8
	set_visible
	delay_16
	set_invisible
	delay_16
	set_visible
	step_end
}

// Munchlax & Snorlax -------------------------------------------------------------------------
script EventScript_SetMunchlaxFamilyGfx {
	special(ShouldStaticEncounterBeFirstStage)
	if (var(VAR_RESULT) == TRUE) {
		goto(EventScript_SetMunchlaxGfx)
	}
	if (!flag(FLAG_BADGE04_GET)) {
		goto(EventScript_SetMunchlaxGfx)
	}
	if (flag(FLAG_BADGE04_GET)) {
		goto(EventScript_SetSnorlaxGfx)
	}
	return
}

script EventScript_SetMunchlaxGfx {
	setvar(VAR_OBJ_GFX_ID_1, OBJ_EVENT_GFX_MUNCHLAX)
	return
}

script EventScript_SetSnorlaxGfx {
	setvar(VAR_OBJ_GFX_ID_1, OBJ_EVENT_GFX_SNORLAX)
	return
}

script EventScript_Snorlax {
	msgbox(format("A Pokémon is sprawled out in\na deep and comfortable slumber."), MSGBOX_DEFAULT)
	checkitem(ITEM_BLUE_FLUTE, 1)
	if (var(VAR_RESULT) == TRUE) {
		goto(EventScript_Snorlax_AskUseFlute)
	}
	release
	end
}

script EventScript_Snorlax_AskUseFlute {
	msgbox(format("Do you want to use the Blue Flute?"), MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		goto(EventScript_BattleSnorlax)
	}
	release
	end
}

script EventScript_BattleSnorlax {
	if (!flag(FLAG_BADGE04_GET)) {
		goto(EventScript_BattleMunchlax)
	}
	if (flag(FLAG_TEMP_5)) {
		goto(EventScript_BattleMunchlax)
	}
	msgbox(format("{PLAYER} played the Blue Flute."), MSGBOX_DEFAULT)
	playfanfare(MUS_RG_JIGGLYPUFF)
	delay(400)
	playse(SE_PIN)
	applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_ExclamationMark)
	waitmovement(0)
	applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_Delay48)
	waitmovement(0)
	msgbox(format("The Pokémon woke up!\pIt attacked in a grumpy rage!"), MSGBOX_DEFAULT)
	closemessage
	waitse
	playmoncry(SPECIES_SNORLAX, 2)
	delay(40)
	waitmoncry
	setwildbattle(SPECIES_SNORLAX, 2, ITEM_LEFTOVERS)
	setflag(FLAG_SYS_CTRL_OBJ_DELETE)
	dowildbattle
	clearflag(FLAG_SYS_CTRL_OBJ_DELETE)
	specialvar(VAR_RESULT, GetBattleOutcome)
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		goto(EventScript_RemoveSnorlax)
	}
	if (var(VAR_RESULT) == B_OUTCOME_CAUGHT) {
		goto(EventScript_RemoveSnorlax)
	}
	if (var(VAR_RESULT) == B_OUTCOME_RAN) {
		goto(EventScript_RemoveSnorlax)
	}
	if (var(VAR_RESULT) == B_OUTCOME_PLAYER_TELEPORTED) {
		goto(EventScript_RemoveSnorlax)
	}
	release
	end
}

script EventScript_BattleMunchlax {
	msgbox(format("{PLAYER} played the Blue Flute."), MSGBOX_DEFAULT)
	playfanfare(MUS_RG_JIGGLYPUFF)
	delay(400)
	playse(SE_PIN)
	msgbox(format("The Pokémon woke up!\pIt attacked in a grumpy rage!"), MSGBOX_DEFAULT)
	closemessage
	waitse
	playmoncry(SPECIES_MUNCHLAX, 2)
	delay(40)
	waitmoncry
	setwildbattle(SPECIES_MUNCHLAX, 2, ITEM_LEFTOVERS)
	setflag(FLAG_SYS_CTRL_OBJ_DELETE)
	dowildbattle
	clearflag(FLAG_SYS_CTRL_OBJ_DELETE)
	specialvar(VAR_RESULT, GetBattleOutcome)
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		goto(EventScript_RemoveSnorlax)
	}
	if (var(VAR_RESULT) == B_OUTCOME_CAUGHT) {
		goto(EventScript_RemoveSnorlax)
	}
	if (var(VAR_RESULT) == B_OUTCOME_RAN) {
		goto(EventScript_RemoveSnorlax)
	}
	if (var(VAR_RESULT) == B_OUTCOME_PLAYER_TELEPORTED) {
		goto(EventScript_RemoveSnorlax)
	}
	release
	end
}

script EventScript_RemoveSnorlax {
	goto(Common_EventScript_RemoveStaticPokemon)
	end
}

